# CONFIGURAÇÕES DA CLÍNICA (EXEMPLO)
# Caso o projeto seja expandido para integrar serviços dinâmicos no futuro,
# configure as chaves reais em um arquivo local `.env` (que já está no .gitignore)
# e NUNCA envie o arquivo `.env` para o GitHub.

# Configuração de Envio de E-mails (Ex: EmailJS, SendGrid ou Formspree)
EMAIL_SERVICE_API_KEY=sua_chave_de_api_aqui
EMAIL_TEMPLATE_ID=seu_template_id_aqui
EMAIL_USER_ID=seu_user_id_aqui

# Integração do WhatsApp (caso precise de token de API oficial)
WHATSAPP_API_TOKEN=seu_token_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_phone_id_aqui

# Configurações do Ambiente
NODE_ENV=development
PORT=3000
